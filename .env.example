# Copy this file to .env and fill in values as needed.
# Optional direct Platform API mode. Codex OAuth mode does not need this key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# OpenAI Codex OAuth mode, modeled after OpenClaw's ChatGPT/Codex route.
# This is not the normal OpenAI Platform API key route.
RTST_CODEX_BASE_URL=https://chatgpt.com/backend-api
RTST_CODEX_MODEL=gpt-5.5
RTST_CODEX_REASONING_EFFORT=low
RTST_CODEX_REASONING_SUMMARY=auto
# Optional. Some Codex backend models reject this parameter; leave unset by default.
# RTST_CODEX_MAX_OUTPUT_TOKENS=120
RTST_CODEX_OAUTH_AUTH_URL=https://auth.openai.com/oauth/authorize
RTST_CODEX_OAUTH_TOKEN_URL=https://auth.openai.com/oauth/token
RTST_CODEX_OAUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
RTST_CODEX_OAUTH_SCOPE=openid profile email offline_access
RTST_CODEX_OAUTH_CALLBACK_HOST=localhost
RTST_CODEX_OAUTH_CALLBACK_PORT=1455
RTST_CODEX_OAUTH_CALLBACK_PATH=/auth/callback
RTST_CODEX_ORIGINATOR=openclaw

# Local debug log. This logs OCR text and translated text snippets for diagnosis.
RTST_LOG_FILE=rtst_debug.log
RTST_LOG_LEVEL=INFO

# Automatic subtitle change detection. OCR runs after a visual change settles,
# not on every scan tick. Raise the threshold if moving backgrounds cause noise.
RTST_SCAN_INTERVAL_MS=120
RTST_SUBTITLE_STABLE_MS=220
RTST_SUBTITLE_MAX_WAIT_MS=850
RTST_VISUAL_CHANGE_THRESHOLD=1.5

# Saves the last image sent to OCR for debugging empty OCR results.
RTST_SAVE_LAST_CAPTURE=1
RTST_LAST_CAPTURE_PATH=rtst_last_capture.png

# Browser DOM subtitle mode. Launch Chrome with run_rtst_browser_dom.bat,
# then set Subtitle source to browser_dom in the app.
RTST_DOM_POLL_INTERVAL_MS=250
RTST_BROWSER_DEBUG_URL=http://127.0.0.1:9222
# Optional tab title or URL substring, useful when multiple tabs are open.
RTST_BROWSER_TAB_FILTER=
# Optional CSS selector. Leave empty to use built-in common subtitle selectors.
RTST_BROWSER_SUBTITLE_SELECTOR=

# Desktop OAuth proxy defaults. These point to the included local demo proxy.
RTST_PROXY_URL=http://127.0.0.1:8787
RTST_OAUTH_AUTH_URL=http://127.0.0.1:8787/authorize
RTST_OAUTH_TOKEN_URL=http://127.0.0.1:8787/token
RTST_OAUTH_CLIENT_ID=rtst-desktop
RTST_OAUTH_SCOPE=translate

# Demo proxy login. Change these before sharing the proxy outside your machine.
RTST_OAUTH_USERNAME=rtst
RTST_OAUTH_PASSWORD=change-me

# Optional. Only needed when using the Tesseract OCR engine.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
